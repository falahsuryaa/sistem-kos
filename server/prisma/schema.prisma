// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TENANT
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SETTLEMENT
  CANCEL
  DENY
  EXPIRE
  FAILURE
  REFUND
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintCategory {
  ELECTRICITY
  WATER
  INTERNET
  ROOM_DAMAGE
  COMMON_FACILITY
  OTHER
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ExpenseCategory {
  ELECTRICITY
  WATER
  INTERNET
  MAINTENANCE
  CLEANING
  SALARY
  OTHER
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(TENANT)
  phone         String?
  avatar        String?
  isActive      Boolean  @default(true)
  refreshToken  String?
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Room {
  id            String     @id @default(uuid())
  roomNumber    String     @unique
  name          String
  floor         Int        @default(1)
  size          Float?
  capacity      Int        @default(1)
  monthlyPrice  Decimal    @db.Decimal(12, 2)
  yearlyPrice   Decimal?   @db.Decimal(12, 2)
  status        RoomStatus @default(AVAILABLE)
  description   String?
  photos        String[]   @default([])
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  facilities    RoomFacility[]
  tenants       Tenant[]
  invoices      Invoice[]
  bookings      Booking[]

  @@map("rooms")
}

model Facility {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       RoomFacility[]

  @@map("facilities")
}

model RoomFacility {
  id         String   @id @default(uuid())
  roomId     String
  facilityId String
  createdAt  DateTime @default(now())

  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([roomId, facilityId])
  @@map("room_facilities")
}

model Tenant {
  id            String    @id @default(uuid())
  userId        String    @unique
  roomId        String?
  fullName      String
  nik           String    @unique
  phone         String
  email         String
  gender        String
  birthDate     DateTime?
  address       String?
  ktpPhoto      String?
  photo         String?
  checkInDate   DateTime
  checkOutDate  DateTime?
  isActive      Boolean   @default(true)
  qrCode        String?
  emergencyContact String?
  emergencyPhone   String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  invoices      Invoice[]
  complaints    Complaint[]
  bookings      Booking[]

  @@map("tenants")
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  tenantId        String
  roomId          String
  periodMonth     Int
  periodYear      Int
  amount          Decimal       @db.Decimal(12, 2)
  lateFee         Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(12, 2)
  dueDate         DateTime
  paidAt          DateTime?
  status          InvoiceStatus @default(PENDING)
  notes           String?
  snapToken       String?
  snapRedirectUrl String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room            Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@unique([tenantId, periodMonth, periodYear])
  @@map("invoices")
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String
  orderId         String        @unique
  amount          Decimal       @db.Decimal(12, 2)
  paymentType     String?
  transactionId   String?
  transactionStatus String?
  fraudStatus     String?
  status          PaymentStatus @default(PENDING)
  snapToken       String?
  rawResponse     Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Complaint {
  id          String            @id @default(uuid())
  tenantId    String
  title       String
  description String
  category    ComplaintCategory @default(OTHER)
  status      ComplaintStatus   @default(PENDING)
  photos      String[]          @default([])
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("complaints")
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String   @default("GENERAL")
  isActive    Boolean  @default(true)
  isPinned    Boolean  @default(false)
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Expense {
  id          String          @id @default(uuid())
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  date        DateTime
  description String?
  receipt     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

model Booking {
  id            String        @id @default(uuid())
  roomId        String
  tenantId      String?
  fullName      String
  email         String
  phone         String
  nik           String
  checkInDate   DateTime
  duration      Int           @default(1)
  notes         String?
  status        BookingStatus @default(PENDING)
  dpAmount      Decimal?      @db.Decimal(12, 2)
  adminNotes    String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  room          Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant        Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
